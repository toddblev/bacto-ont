# OS / editor clutter
.DS_Store
**/.ipynb_checkpoints/
*.ipynb.bak
*_bkup.ipynb

# Large raw signal + basecaller intermediates — hosted externally / instructor-only,
# fetched or regenerated by the notebook. Never committed.
pod5/*.pod5
basecalls/*
!basecalls/calls_demo.bam
demux_out/
_prep/

# Derived read data — regenerated by running the notebook
*.fastq
*.fastq.gz

# Reference genomes — downloaded by the notebook's reference cell (kept out of git)
reference_seqs/*.fna
reference_seqs/*.fasta
reference_seqs/*.fa
reference_seqs/*.fai
reference_seqs/*.mmi

# Mapping outputs — regenerated by the minimap2 cells (the large ones)
mapping_bam/*.bam
mapping_bam/*.bai

# QC outputs — regenerated by NanoPlot / fastplong / NanoComp.
# Keep only the static model comparison that ships with the repo.
qc/*
!qc/model_compare/

# stray fastplong/fastp default reports (written to CWD if --html/--json not set)
/fastplong.html
/fastplong.json
/fastp.html
/fastp.json

# Coverage / assembly working files
*.mosdepth.*
*.regions.bed.gz*
*.per-base.bed.gz*
flye_*/

# dorado log — may leak local machine paths
dorado.log

# NOTE: intentionally TRACKED — qc/model_compare/ (static model-comparison HTML shipped
# with the repo), analysis/ scripts, cheatsheets/, reference_seqs/*.py helpers,
# environment.yml, README.md, LICENSE, and bacto_ont.ipynb.
